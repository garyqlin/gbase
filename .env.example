# Gbase Configuration
# Copy this file to .env and fill in your values

# OpenAI-compatible API configuration (required)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Default model (optional, defaults to gpt-4o)
MODEL=gpt-4o

# Identity configuration
IDENTITY=default

# Skills directory (optional, defaults to ./skills)
SKILLS_DIR=skills

# Scheduler owner ID (optional)
LEARN_OWNER=

# HTTP API authentication token (optional — leave empty for no auth)
GBASE_API_TOKEN=

# Village OS connectivity (optional)
VILLAGE_OS_URL=http://127.0.0.1:8765

# Feishu/Lark Bot Configuration (required for bot mode)
# Get these from Feishu Open Platform → App → Credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_PORT=8440

# DeepSeek API (optional, used by hive_mind)
OPPRIME_DEEPSEEK_API_KEY=
